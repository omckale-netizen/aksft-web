rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Yardimci: Rol tabanli yetki kontrolu
    // Super admin — email bazli, her zaman tam yetki (kurtarma)
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'info@onyedimedya.com';
    }
    // Kullanici rolunu users koleksiyonundan oku
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isUserActive() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }
    function isAdmin() {
      return isSuperAdmin() || (request.auth != null && isUserActive() && getUserRole() == 'admin');
    }
    function isEditor() {
      return isAdmin() || (request.auth != null && isUserActive() && getUserRole() == 'editor');
    }
    function isViewer() {
      return isEditor() || (request.auth != null && isUserActive() && getUserRole() == 'viewer');
    }
    // allowedPages kontrolü — editor'un yazma yetkisini sayfa bazında sınırlar
    // Admin her şeye erişir (kısıt yok). Editor için users/{uid}.allowedPages içinde sayfa adı olmalı.
    function hasPage(page) {
      return isAdmin() || (
        isEditor()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.allowedPages is list
        && page in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.allowedPages
      );
    }
    // Kullanıcının kendi e-postası (token'dan) — activity log / sent_mail sahipliği için
    function myEmail() { return request.auth.token.email; }

    // Kullanici yonetimi: sadece admin yonetir, her kullanici kendi belgesini okuyabilir (role vb.)
    // ÖNEMLİ: Rol değeri validate edilir — 'admin'/'editor'/'viewer' dışı kabul edilmez
    // İstisna: kullanıcı kendi dokümanında sadece 'name' ve 'photoURL' alanlarını değiştirebilir
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if isAdmin()
        && request.resource.data.role in ['admin','editor','viewer'];
      allow update: if (
          isAdmin()
          && request.resource.data.role in ['admin','editor','viewer']
        ) || (
          // Kullanıcı kendi ismini/fotoğrafını güncelleyebilir — başka alan değiştiremez
          request.auth != null
          && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'photoURL'])
        );
      allow delete: if isAdmin();
    }

    // Icerik yonetimi: herkes okuyabilir; editor yazabilir — SAYFA YETKİSİ ŞARTI VAR
    match /venues/{docId} {
      allow read: if true;
      allow create, update: if hasPage('venues');
      allow delete: if isAdmin();
    }

    match /places/{docId} {
      allow read: if true;
      allow create, update: if hasPage('villages');
      allow delete: if isAdmin();
    }

    match /villages/{docId} {
      allow read: if true;
      allow create, update: if hasPage('villages');
      allow delete: if isAdmin();
    }

    match /routes/{docId} {
      allow read: if true;
      allow create, update: if hasPage('routes');
      allow delete: if isAdmin();
    }

    // Iletisim mesajlari: herkes yazabilir; editor okur ve update edebilir (label vb.)
    // messages sayfa yetkisi şart — sadece yetkili editor mesajları okuyabilir
    match /messages/{docId} {
      allow create: if true;
      allow read, update: if hasPage('messages');
      allow delete: if isAdmin();
    }

    // Gonderilen mailler arsivi: admin hepsini okur; editor sadece KENDİ gönderdiklerini okur/yazar
    // sent_mails dokümanındaki 'user' alanı göndericinin e-postasıdır
    match /sent_mails/{docId} {
      allow read: if isAdmin() || (
        isEditor() && resource.data.user == myEmail()
      );
      allow create: if hasPage('messages')
        && request.resource.data.user == myEmail();
      allow update: if isAdmin() || (
        isEditor() && resource.data.user == myEmail()
      );
      allow delete: if isAdmin();
    }

    // Analitik: herkes yazabilir (anonim kullanici izleme), sadece admin okuyabilir
    // Sema validasyonu + boyut kisiti ile spam/storage abuse onleme
    // Izin verilen alanlar: views, lastViewed, id + action_count/action_last (phone, whatsapp, directions, share, website, instagram)
    function isValidAnalyticsKeys(keys) {
      return keys.hasOnly(['views','lastViewed','id',
        'phone_count','phone_last',
        'whatsapp_count','whatsapp_last',
        'directions_count','directions_last',
        'share_count','share_last',
        'website_count','website_last',
        'instagram_count','instagram_last']);
    }
    match /analytics/{docId} {
      allow create: if isValidAnalyticsKeys(request.resource.data.keys());
      allow update: if isValidAnalyticsKeys(request.resource.data.keys());
      allow read, delete: if isAdmin();
    }

    match /analytics_events/{docId} {
      allow create: if
        // Sadece belirli alanlar, metin uzunluklari sinirli
        request.resource.data.keys().hasOnly(['type','target','meta','action','pageId','venueId','ts','timestamp','userAgent','referrer','path'])
        && (!('type' in request.resource.data) || (request.resource.data.type is string && request.resource.data.type.size() < 50))
        && (!('target' in request.resource.data) || (request.resource.data.target is string && request.resource.data.target.size() < 200))
        && (!('userAgent' in request.resource.data) || (request.resource.data.userAgent is string && request.resource.data.userAgent.size() < 300));
      allow read, delete: if isAdmin();
    }

    // Favoriler: herkes okuyabilir (kod ile paylasim), yazma validasyonlu
    match /favorites/{docId} {
      allow read: if true;
      allow create, update: if
        // Sadece izin verilen alanlar
        request.resource.data.keys().hasOnly(['venues', 'places', 'updatedAt'])
        // venues ve places array olmali
        && request.resource.data.venues is list
        && request.resource.data.places is list
        // Maksimum 50 favori (spam onleme)
        && request.resource.data.venues.size() <= 50
        && request.resource.data.places.size() <= 50;
      allow delete: if isAdmin();
    }

    // Bot onay bekleyenler: herkes yazabilir (sema + boyut kisiti ile), sadece admin yonetebilir
    // Mekan ekleme formundan gelen veri — tum alanlar validate edilir (storage abuse + XSS payload onleme)
    function isValidPendingVenue() {
      let d = request.resource.data;
      let allowedKeys = ['ownerName','ownerEmail','ownerPhone','title','category','location','address','mapsLink','shortDesc','description','phones','tags','website','instagram','weeklyHours','checkin','checkout','rooms','facilities','seasonal','seasonStart','seasonEnd','images','consentGiven','consentDate','userAgent','submittedAt','status','refNo','updatedAt','editedAt'];
      return d.keys().hasOnly(allowedKeys)
        // Zorunlu alanlar
        && d.ownerName is string && d.ownerName.size() > 0 && d.ownerName.size() <= 100
        && d.ownerEmail is string && d.ownerEmail.size() > 0 && d.ownerEmail.size() <= 100
        && d.ownerPhone is string && d.ownerPhone.size() > 0 && d.ownerPhone.size() <= 30
        && d.title is string && d.title.size() > 0 && d.title.size() <= 150
        && d.category is string && d.category.size() <= 30
        && d.location is string && d.location.size() <= 100
        && d.shortDesc is string && d.shortDesc.size() <= 300
        && d.description is string && d.description.size() <= 5000
        // Opsiyonel alanlar (varsa) tip ve boyut
        && (!('address' in d) || (d.address is string && d.address.size() <= 300))
        && (!('mapsLink' in d) || (d.mapsLink is string && d.mapsLink.size() <= 500))
        && (!('website' in d) || (d.website is string && d.website.size() <= 200))
        && (!('instagram' in d) || (d.instagram is string && d.instagram.size() <= 100))
        && (!('userAgent' in d) || (d.userAgent is string && d.userAgent.size() <= 300))
        && (!('refNo' in d) || (d.refNo is string && d.refNo.size() <= 20))
        && (!('status' in d) || (d.status is string && d.status in ['pending','updated','revision','approved','rejected','trashed']))
        // Array alanlarin element sayisi
        && (!('phones' in d) || (d.phones is list && d.phones.size() <= 10))
        && (!('tags' in d) || (d.tags is list && d.tags.size() <= 10))
        && (!('weeklyHours' in d) || (d.weeklyHours is list && d.weeklyHours.size() <= 10))
        && (!('rooms' in d) || (d.rooms is list && d.rooms.size() <= 20))
        && (!('facilities' in d) || (d.facilities is list && d.facilities.size() <= 30))
        && (!('images' in d) || (d.images is list && d.images.size() <= 10));
    }
    match /pending_venues/{docId} {
      allow create: if isValidPendingVenue();
      allow read, update: if isEditor();
      allow delete: if isAdmin();
    }

    match /pending_places/{docId} {
      allow create: if
        request.resource.data.keys().hasOnly(['ownerName','ownerEmail','ownerPhone','title','category','location','description','images','consentGiven','consentDate','submittedAt','status','refNo','userAgent'])
        && request.resource.data.ownerName is string && request.resource.data.ownerName.size() > 0 && request.resource.data.ownerName.size() <= 100
        && request.resource.data.ownerEmail is string && request.resource.data.ownerEmail.size() > 0 && request.resource.data.ownerEmail.size() <= 100
        && request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 150;
      allow read, update: if isEditor();
      allow delete: if isAdmin();
    }

    // Site ayarlari: herkes okuyabilir (logo vb.), sadece admin yazabilir
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Galeri: editor okur/yazar, admin siler
    match /gallery/{docId} {
      allow read: if isViewer();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // Blog: herkes okuyabilir, editor yazar, sadece admin siler
    match /blog_posts/{docId} {
      allow read: if true;
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    // Aktivite logu:
    // - Admin tüm logları okur
    // - Editor/viewer sadece KENDİ aksiyonlarını okur (resource.data.user == kendi email)
    // - Yazma: editor+ (kendi adına)
    // - Update/delete: sadece admin
    match /activity_logs/{docId} {
      allow read: if isAdmin() || (
        isViewer() && resource.data.user == myEmail()
      );
      allow create: if isEditor()
        && request.resource.data.user == myEmail();
      allow update, delete: if isAdmin();
    }

    // Kullanıcı presence (online durumu):
    // - Herkes (authenticated) tüm presence'ları okuyabilir (sidebar'da yeşil nokta için)
    // - Sadece kendi dokümanını yazabilir
    match /presence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['uid','email','name','lastHeartbeat','photoURL']);
    }

    // Admin todo/hatirlatma sistemi:
    // - Admin her şey
    // - Editor okuma: kendine atanmış + kendi oluşturduğu + atanmamış (genel)
    // - Editor create: kendi createdBy'siyle (kendi adına başkasına atama yapabilir, admin yetki verdiyse)
    // - Editor update/delete: kendi oluşturduğu VEYA kendine atanmış
    match /admin_todos/{docId} {
      allow read: if isAdmin() || (
        isEditor() && (
          resource.data.assignedTo == null
          || resource.data.assignedTo == request.auth.uid
          || resource.data.createdBy == myEmail()
        )
      );
      allow create: if isEditor()
        && request.resource.data.createdBy == myEmail();
      allow update, delete: if isAdmin() || (
        isEditor() && (
          resource.data.createdBy == myEmail()
          || resource.data.assignedTo == request.auth.uid
        )
      );
    }

    // Diger tum koleksiyonlar: varsayilan olarak engelle
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
