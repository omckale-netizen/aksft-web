rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Yardimci: Admin mi kontrol et
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'info@onyedimedya.com';
    }

    // Mekan gorselleri: herkes gorebilir, sadece admin yukleyebilir
    match /venues/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024          // Maks 5MB
        && request.resource.contentType.matches('image/.*'); // Sadece gorsel
    }

    // Site ayarlari (logo, favicon, og-image)
    match /site/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024          // Maks 5MB
        && request.resource.contentType.matches('image/.*');
    }

    // Galeri gorselleri
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Diger tum dosyalar: engelle
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
