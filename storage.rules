rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Yardimci: Admin mi kontrol et (super admin e-posta listesi)
    // Firestore ve _verify.js ile tutarli olmasi icin her iki super admin de dahil
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'info@onyedimedya.com' ||
        request.auth.token.email == 'onyedimedya@gmail.com'
      );
    }

    // Mekan gorselleri: herkes gorebilir, sadece admin yukleyebilir
    match /venues/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024          // Maks 5MB
        && request.resource.contentType.matches('image/.*'); // Sadece gorsel
    }

    // Site ayarlari (logo, favicon, og-image, llms-full.txt)
    match /site/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024;
    }

    // Yedeklemeler (sadece admin)
    match /backups/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin()
        && request.resource.size < 20 * 1024 * 1024;
    }

    // Blog ve icerik gorselleri
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Galeri gorselleri
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Kullanıcı profil fotoğrafları — sadece kendi fotoğrafını yükler
    // Path: avatars/{uid}/photo.jpg
    match /avatars/{uid}/{fileName} {
      allow read: if true; // panel içinde herkes görebilir
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 1 * 1024 * 1024       // Maks 1MB
        && request.resource.contentType.matches('image/.*');
    }

    // Mekan basvuru gorselleri (anonim upload — mekan-ekle.html formu)
    // Path: pending/{timestamp}_{n}.jpg
    // Anonim kullanicilar yazabilir ama: sadece gorsel, maks 5MB, admin silebilir
    // Abuse riski: Firestore'da pending_venues/{refNo} kaydi + IP rate limit (/api/notify)
    match /pending/{fileName} {
      allow read: if true; // admin panel onizleme icin
      allow write: if request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    // Diger tum dosyalar: engelle
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
